{
  "name": "nanus-skill-system-registry",
  "created_at": "2026-06-30T01:22:53Z",
  "status": "planned",
  "purpose": "Define Nanus Skill Hub sources, package model, official Manus-compatible behavior, review gates, and invocation routing.",
  "official_source_references": [
    {
      "name": "Manus Skills documentation",
      "url": "https://manus.im/docs/features/skills",
      "observed_capabilities": [
        "SKILL.md-centered package concept",
        "build with Manus",
        "upload package",
        "official Skill Library",
        "GitHub import",
        "slash command invocation",
        "Project Skill Library",
        "Team Skill Library"
      ]
    },
    {
      "name": "Manus Project Skills announcement",
      "url": "https://manus.im/blog/manus-project-skills",
      "observed_capabilities": [
        "project-level shared skills",
        "workspace/team reuse pattern"
      ]
    }
  ],
  "package_model": {
    "root_file": "SKILL.md",
    "optional_files": [
      "manifest.json",
      "examples/",
      "tests/",
      "scripts/",
      "assets/",
      "README.md",
      "LICENSE"
    ],
    "required_metadata": [
      "id",
      "name",
      "version",
      "source_type",
      "source_ref",
      "checksum",
      "trust_label",
      "declared_permissions",
      "compatible_workers"
    ],
    "trust_labels": [
      "official_manus",
      "nanus_official",
      "team",
      "project",
      "github",
      "local",
      "generated",
      "reference_only"
    ]
  },
  "sources": [
    {
      "type": "generated",
      "label": "Build with Nanus",
      "enabled_by_default": false,
      "requires_review": true,
      "install_inputs": [
        "natural_language_description",
        "prior_run_id",
        "artifact_id"
      ]
    },
    {
      "type": "upload",
      "label": "Upload Skill",
      "enabled_by_default": false,
      "requires_review": true,
      "install_inputs": [
        "SKILL.md",
        "folder",
        "zip_archive"
      ]
    },
    {
      "type": "github",
      "label": "GitHub Import",
      "enabled_by_default": false,
      "requires_review": true,
      "install_inputs": [
        "repo_url",
        "path",
        "branch",
        "tag",
        "release_asset"
      ]
    },
    {
      "type": "local_path",
      "label": "Local Path",
      "enabled_by_default": false,
      "requires_review": true,
      "install_inputs": [
        "absolute_path",
        "workspace_relative_path"
      ]
    },
    {
      "type": "official_manus_catalog",
      "label": "Official Manus Catalog",
      "enabled_by_default": false,
      "requires_review": true,
      "install_inputs": [
        "public_package_url",
        "compatible_export",
        "user_provided_package"
      ],
      "fallback_behavior": "reference_only_when_package_source_is_missing"
    }
  ],
  "scopes": [
    {
      "scope": "user",
      "description": "Available only to the current user."
    },
    {
      "scope": "project",
      "description": "Pinned to the active Nanus project after review."
    },
    {
      "scope": "team",
      "description": "Shared team library entry requiring owner approval and promotion history."
    }
  ],
  "permissions": {
    "filesystem": [
      "none",
      "read_workspace",
      "write_workspace",
      "disposable_full_access"
    ],
    "network": [
      "deny",
      "allowlist",
      "open"
    ],
    "tools": [
      "mcp",
      "browser",
      "terminal",
      "codex",
      "claude_code",
      "artifact_studio",
      "email",
      "calendar",
      "github"
    ],
    "approval_defaults": {
      "generated": "review_before_enable",
      "github": "review_before_enable",
      "official_manus": "review_before_run",
      "reference_only": "cannot_run",
      "local": "review_before_enable"
    }
  },
  "invocation": {
    "slash_command_format": "/<skill-name>",
    "source_qualified_format": "/<source>:<skill-name>",
    "examples": [
      "/deck-from-brief",
      "/research-brief",
      "/codex-refactor",
      "/claude-review",
      "/manus:official-skill-name"
    ],
    "run_events": [
      "skill.resolved",
      "skill.review.required",
      "skill.started",
      "skill.permission.requested",
      "skill.worker.dispatched",
      "skill.artifact.created",
      "skill.verification.completed",
      "skill.completed",
      "skill.failed"
    ]
  },
  "ui_surfaces": [
    "left_sidebar_pinned_skills",
    "skill_hub_browse",
    "skill_hub_installed",
    "skill_builder",
    "skill_review",
    "composer_slash_command_picker",
    "run_timeline_skill_step",
    "right_inspector_skill_tab"
  ],
  "hard_rules": [
    "No skill runs without a concrete RunPolicy snapshot.",
    "No official Manus skill is bundled unless the package is public, exported by the user, or otherwise licensed for use.",
    "Generated and imported skills start disabled.",
    "Every skill invocation records package version, source, checksum, permissions, and verification result.",
    "Reference-only official catalog entries cannot execute."
  ]
}
