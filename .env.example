# Nanus backend/runtime knobs
# Copy to your shell profile or export before npm run dev:full.

# Optional live LLM path. Without this, Nanus uses deterministic local fallback output.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
NANUS_ANTHROPIC_ENABLED=auto
NANUS_ANTHROPIC_TIMEOUT=45
NANUS_ANTHROPIC_MAX_TOKENS=4096
# Direct chat/run payloads are still bounded; document upload/RAG should be used for very large source files.
NANUS_LLM_MAX_INPUT_CHARS=90000

# Codex bridge. dev:full enables this by default so local runs use Codex CLI instead of deterministic fallback.
NANUS_CODEX_ENABLED=true
NANUS_CODEX_SANDBOX=read-only
NANUS_CODEX_TIMEOUT=120
NANUS_CODEX_SERVICE_TIER=fast
# CODEX_EXECUTABLE=/absolute/path/to/codex
# NANUS_CODEX_WORKDIR=/absolute/path/to/workspace
NANUS_CODEX_MODEL=gpt-5.4

# SQLite persistence. Defaults to .nanus/nanus.sqlite3.
# NANUS_DB_PATH=.nanus/nanus.sqlite3

# Browser origins allowed to call the backend directly when not using the Vite proxy.
# Comma-separate multiple frontend origins.
# NANUS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Frontend API origin when not using the Vite proxy.
# VITE_NANUS_API_BASE=http://127.0.0.1:8765

# Frontend backend behavior. dev:full sets these automatically.
VITE_NANUS_BACKEND_AUTO=false
VITE_NANUS_RESTORE_BACKEND=false
